#include <iostream>
using namespace std;
#include <cmath>
void input (double& AtempF, double& WspdMPH, double& Dpoint);
void windchill (double& AtempF, double& WspdMPH, double& Wchill);
void cloudbase (double& Atempf, double& Dpoint, double& clodbase);
void output (double& Atempf, double& Dpoint, double& clodbase);

int main()
{
double Wchill;
double AtempF;
double WspdMPH;
double clodbase;
double Dpoint;

cout << "====================\n";
cout << " weather calculator\n";
cout << "====================\n";

cout << "Input the air tempreture (F): ";
cin >> AtempF;

while (!(cin >> AtempF)) {
    cout << "Invalid input, please try again: ";
    cin.clear();
    cin.ignore(10000, '\n');
}

cout << "Input the wind speed (MPH): ";
cin >> WspdMPH;

while (!(cin >> WspdMPH)) {
    cout << "Invalid input, please try again: ";
    cin.clear();
    cin.ignore(10000, '\n');
}

cout << "Input the dew point: ";
cin >> Dpoint;

while (!(cin >> Dpoint)) {
    cout << "Invalid input, please try again: ";
    cin.clear();
    cin.ignore(10000, '\n');
}

windchill(AtempF, WspdMPH, Wchill);
cloudbase (AtempF, Dpoint, clodbase);
cout << "The windchill is: " << Wchill << "degrees fahrenheit";
cout << "\nThe cloud base is: " << clodbase << " feet";
}


void windchill(double& AtempF, double& WspdMPH, double& Wchill) {
Wchill = 35.74 + 0.6215 * AtempF - 35.75*pow(WspdMPH, .16) + .4275 * AtempF*pow(WspdMPH, .16); }

void cloudbase (double& Atempf, double& Dpoint, double& clodbase) {
clodbase = 1000 * (Atempf - Dpoint)/4.4; }
