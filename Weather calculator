#include <iostream>
using namespace std;
#include <cmath> // these are meant to allows us to power statements
void input (double& aTempf, double& wspdMPH, double& dPoint); // this funtions runs the user puts the variables

double windchill (double& aTempf, double& wspdMPH, double& wChill); // this function runs the windchill calculation

double cloudbase (double& aTempf, double& dPoint, double& clodBase); // this function run the cloud base calculation

void output (double& aTempf, double& dPoint, double& wChill, double& clodBase);
// this function output the two caluclation of the previous function and explains them to the user

int main()
{
	cout << "====================\n";
	cout << " weather calculator\n";
	cout << "====================\n";
	// title statement to tell the user what the program is
	double aTempf; // this is the variable for the air tempreture measured in fahrenheit
	double dPoint; // this is the variable for the dew point
	double clodBase; // this is the variable for cloud base
	double wspdMPH; // this is the variable for the wind speed
	double wChill; // this is the variable for the wind chill

	input(aTempf, wspdMPH, dPoint); // this function ask the user to input air temp, dew point, and wind speed
	windchill(aTempf, wspdMPH, wChill); // this function runs the wind chill calculation with the number inputted from input
	cloudbase(aTempf, dPoint, clodBase); // this function runs the cloud base calculation with the number inputted from input
	output(aTempf, dPoint, clodBase, wChill); // this out puts the number from wind chill and cloud base with explanations
}


void input (double& aTempf, double& wspdMPH, double& dPoint) {
	cout << "Input the air tempreture (F): "; // the input for the air tempreture.
	while (!(cin >> aTempf)) { // this checks if the value inputted in valid
		cout << "Invalid input. Try again: "; // if the input is not valid it cout a message
		cin.clear(); // the invalid input is cleared
		cin.ignore(10000, '\n'); // this causes the program input to go back
	}

	cout << "Input the wind speed (MPH): "; // input for wind speed
	while (!(cin >> wspdMPH)) { // this checks if the input is valid
		cout << "Invalid input. Try again: "; // the invalid statement if a input that cant be read is inputted
		cin.clear(); // this clears the input if it is seen as not valid
		cin.ignore(10000, '\n');; // this causes the program input to go back
	}

	cout << "Input the dew point: "; // the input for the dew point
	while (!(cin >> dPoint)) { // this checks if the value inputted in valid
		cout << "Invalid input, please try again: "; // the invalid statement if a input that cant be read is inputted
		cin.clear(); // this clears the input if it is seen as not valid
		cin.ignore(10000, '\n'); // this causes the program input to go back to the user input

	}
}

double windchill (double& aTempf, double& wspdMPH, double& wChill) { // connects the wind chill to the void
	wChill = 35.74 + 0.6215 * aTempf - 35.75*pow(wspdMPH, .16) + .4275 * aTempf*pow(wspdMPH, .16);
	return wChill; // this is the calculation for wind chill which is then sent to output
}

double cloudbase (double& aTempf, double& dPoint, double& clodBase) { // this connects to the void cloudbase
	clodBase = 1000 * (aTempf - dPoint)/4.4;
	return clodBase; // this is the calculation to find the cloud base which is then set to output
}

void output (double& aTempf, double& dPoint, double& wChill, double& clodBase) {
	cout << "The windchill is: " << clodBase << " degrees fahrenheit"; // this displays the value for windchill
	cout << "\nThe cloud base is: " << wChill << " feet"; // this is the output to tell the user what the cloud base is
}
